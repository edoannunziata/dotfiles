[user]
	email = annunziata.edoardo@outlook.com
	name = Edoardo Annunziata
[init]
	defaultBranch = master
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[core]
    editor = vim
    visual = vim
	autocrlf = input
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
